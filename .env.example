# --- Database Settings ---
# Local SQLite fallback option or external PostgreSQL URI
# For Docker Compose, the default is: postgresql://postgres:postgres@db:5432/hcp_crm
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hcp_crm

# --- Security ---
SECRET_KEY=supersecretkeyforhcpmoduledevelopment
ACCESS_TOKEN_EXPIRE_MINUTES=480

# --- AI Core Config ---
# Groq API Key required for real LLM features.
# Generate a key at: https://console.groq.com/
GROQ_API_KEY=

# Primary and Context Models
PRIMARY_MODEL=gemma2-9b-it
CONTEXT_MODEL=llama-3.3-70b-versatile

# --- Frontend Ports ---
# For development, Vite defaults to 3000
VITE_API_URL=http://localhost:8000
