# --- Database Configuration ---
# PostgreSQL Connection URL (FastAPI connects to this by default, fallback to SQLite if offline)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hcp_crm

# --- Security Configuration ---
# Secret key used for JWT token encoding/decoding
SECRET_KEY=supersecretkeyforhcpmoduledevelopment

# --- AI Core Config ---
# Groq API Key required for real LLM features.
# Generate a key at: https://console.groq.com/
GROQ_API_KEY=

# Primary and Context Models
PRIMARY_MODEL=gemma2-9b-it
CONTEXT_MODEL=llama-3.3-70b-versatile

# --- Frontend Ports ---
# For local dev running, Vite targets port 8000 for backend API calls
VITE_API_URL=http://localhost:8000
